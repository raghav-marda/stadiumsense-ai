# Choose ONE provider. LLM_PROVIDER controls which one is used.
#
# RECOMMENDED IF YOU DON'T HAVE A CREDIT CARD: gemini
#   Google AI Studio (aistudio.google.com) issues API keys with just a
#   Google account — no card, no phone verification, generous free tier.

LLM_PROVIDER=gemini          # "anthropic", "openai", or "gemini"

# --- Google Gemini (no credit card required) ---------------------------
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Anthropic (card required for billing, even for free trial credit) -
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (card required) --------------------------------------------
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Optional: used only for display in the footer / about section
NEXT_PUBLIC_APP_NAME=StadiumSense AI
